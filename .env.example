VITE_API_BASE_URL=http://localhost:5000
FLASK_APP=run.py
FLASK_ENV=development
APP_ENV=development
APP_VERSION=0.3.0
PORT=5000
DATABASE_PATH=backend/app/db/student_os.db
OPENAI_API_KEY=your_future_llm_key_here
MENTOR_PROVIDER=local
ENABLE_REQUEST_LOGGING=true
ENABLE_RATE_LIMITING=true
RATE_LIMIT_WINDOW_SECONDS=60
INTAKE_RATE_LIMIT=12
MENTOR_RATE_LIMIT=20
